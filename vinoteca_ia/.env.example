# ── LLM API ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_PRIMARY=claude-3-5-sonnet-20241022
LLM_FALLBACK=gpt-4o-mini

# ── PostgreSQL ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://vinoteca:vinoteca_dev@localhost:5432/vinoteca_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
IDEMPOTENCY_TTL_SECONDS=1800

# ── MongoDB (solo para migración) ────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=vinoteca_mongo

# ── Seguridad ────────────────────────────────────────────────────────
API_SECRET_KEY=cambia_esto_en_produccion
CHANNEL_TOKEN_WEB=token_web_dev

# ── Mercado Pago (mock en desarrollo) ────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-mock-token
MERCADOPAGO_WEBHOOK_SECRET=mock_secret
MERCADOPAGO_MOCK_ENABLED=true

# ── Embeddings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
