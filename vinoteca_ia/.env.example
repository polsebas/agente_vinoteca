# ── LLM API ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Id que empiece con claude- → Anthropic; cualquier otro (gpt-*, o4-*, etc.) → OpenAI.
# Solo OpenAI: poné ambos con prefijo gpt- (u otro id OpenAI) y dejá ANTHROPIC sin usar.
LLM_PRIMARY=claude-3-5-sonnet-20241022
LLM_FALLBACK=gpt-4o-mini

# ── PostgreSQL ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://vinoteca:vinoteca_dev@localhost:5432/vinoteca_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
IDEMPOTENCY_TTL_SECONDS=1800

# TTL (minutos) de la reserva de stock creada por verificar_stock_exacto.
# Si la aprobación humana tarda más, la reserva expira y el agente debe
# re-verificar antes de crear la orden.
STOCK_RESERVA_TTL_MIN=15

# ── MongoDB (solo para migración) ────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=vinoteca_mongo

# ── Seguridad ────────────────────────────────────────────────────────
API_SECRET_KEY=cambia_esto_en_produccion
CHANNEL_TOKEN_WEB=token_web_dev

# Token obligatorio para /pedido/{run_id}/aprobar.
# Si está vacío, el endpoint devuelve 503 (fail-closed): no dejamos abierto
# un endpoint destructivo por descuido.
APPROVAL_API_TOKEN=

# Token obligatorio para /admin/*. Podés reutilizar APPROVAL_API_TOKEN si
# preferís un único secreto operador; en prod recomendamos tokens separados.
ADMIN_API_TOKEN=

# API key opcional para /chat. Si está vacío, el endpoint queda abierto (dev).
# En prod: setealo y exigí header X-Chat-Key.
CHAT_API_KEY=

# Rate limits por identidad (token o IP), ventana de 60s.
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_APPROVAL_PER_MIN=20
RATE_LIMIT_ADMIN_PER_MIN=5

# ── Mercado Pago (mock en desarrollo) ────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-mock-token
MERCADOPAGO_WEBHOOK_SECRET=mock_secret
MERCADOPAGO_MOCK_ENABLED=true

# ── Embeddings ───────────────────────────────────────────────────────
HF_EMBEDDING_MODEL=dccuchile/bert-base-spanish-wwm-uncased
EMBEDDING_DEVICE=auto
EMBEDDING_MAX_LENGTH=512
EMBEDDING_DIM=768

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── AgentOS runtime ─────────────────────────────────────────────────
# Bearer opcional para rutas del OS (Agno). Si lo seteás, la UI en os.agno.com
# debe enviar Authorization: Bearer <mismo valor>.
OS_SECURITY_KEY=
# Con true, /agents, /config, etc. responden aunque la conexión no sea loopback
# (necesario para enlazar os.agno.com contra URL pública/LAN). Solo dev.
AGENTOS_RELAX_LOOPBACK_GUARD=false
# Tracing OpenTelemetry para agentes/teams (requiere exporter externo).
AGENTOS_TRACING=false
# Telemetría mínima de Agno hacia os-api.agno.com. Opt-in: por privacidad
# dejamos el default en false.
AGENTOS_TELEMETRY=false
# Paths expuestos públicamente (comma-separated). El resto (incluidas las
# rutas nativas de AgentOS) queda restringido a loopback vía middleware.
AGENTOS_PUBLIC_PATHS=/health,/chat,/webhook
# RBAC de AgentOS. Con true, AgentOS verifica JWTs con JWT_VERIFICATION_KEY
# (ver docs de Agno) y el factory falla al arrancar si la clave no está
# seteada. Los tokens propios del dominio (APPROVAL_API_TOKEN /
# ADMIN_API_TOKEN / CHAT_API_KEY) siguen funcionando igual.
AGENTOS_AUTHORIZATION=false
JWT_VERIFICATION_KEY=
JWT_ALGORITHM=RS256
